double function(double x)
{
	double y;
	if (x < 2) y = (pow(tan(x), -1) - sin(x)) / pow(x, 3);
	if (x >= 2 && x < 9) y = (exp(cos(x)) * sqrt(pow(x, 2) + 1)) / log(3 + x);
	if (x >= 9) y = sin(2 * x - 5) / (1 + pow(x, 6));
	return y;
}
